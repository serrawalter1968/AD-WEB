---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getShoes } from '../lib/db';

const shoes = await getShoes();
const categories = [...new Set(shoes.map((s) => s.category).filter(Boolean))];
const selectedCategory = Astro.url.searchParams.get('categoria');
const filteredShoes = selectedCategory ? shoes.filter((s) => s.category === selectedCategory) : shoes;
---

<BaseLayout>
  <header class="bg-white/80 backdrop-blur-sm sticky top-0 z-50 border-b border-[#f0ebe7]">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-baseline gap-3">
          <h1 class="font-['Playfair_Display'] text-3xl font-semibold text-[#c9a8a8] tracking-tight">AD</h1>
          <span class="text-[#c9a8a8]/40 text-xs font-light tracking-[0.3em] uppercase hidden sm:block">Web</span>
        </div>
        <nav class="flex items-center gap-8">
          <a href="/" class="text-xs tracking-[0.15em] uppercase text-[#c9a8a8] font-medium border-b border-[#c9a8a8] pb-0.5">Colección</a>
          <a href="/admin/login" class="text-xs tracking-[0.15em] uppercase text-[#b5a5a5] hover:text-[#c9a8a8] transition-colors duration-300">Admin</a>
        </nav>
      </div>
    </div>
  </header>

  <section class="relative overflow-hidden bg-gradient-to-b from-[#faf7f5] via-white to-[#faf7f5]">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full bg-[#f0e4e0]/50 blur-3xl" />
      <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full bg-[#e8d5d0]/30 blur-3xl" />
    </div>
    <div class="relative max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-16 sm:py-24">
      <div class="text-center max-w-2xl mx-auto">
        <span class="text-[#d4b5b5] text-xs tracking-[0.3em] uppercase font-light block mb-6">Nueva Temporada</span>
        <h2 class="font-['Playfair_Display'] text-4xl sm:text-5xl md:text-6xl font-medium text-[#3d3d3d] leading-[1.15] tracking-tight">
          Elegancia que<br/>
          <span class="text-[#c9a8a8] italic">deja huella</span>
        </h2>
        <p class="mt-6 text-[#b5a5a5] text-sm font-light leading-relaxed max-w-md mx-auto">
          Diseños exclusivos para la mujer contemporánea que busca distinguirse con cada paso.
        </p>
      </div>
    </div>
  </section>

  <main class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 pb-20">
    {categories.length > 0 && (
      <div class="flex gap-3 mb-12 flex-wrap justify-center">
        <a href="/" class={`px-6 py-2.5 rounded-full text-xs tracking-[0.08em] font-medium transition-all duration-300 ${!selectedCategory ? 'bg-[#f0e4e0] text-[#c9a8a8]' : 'bg-white text-[#b5a5a5] border border-[#f0ebe7] hover:bg-[#f0e4e0] hover:text-[#c9a8a8]'}`}>
          Todas las categorías
        </a>
        {categories.map((cat) => (
          <a
            href={`/?categoria=${cat}`}
            class={`px-6 py-2.5 rounded-full text-xs tracking-[0.08em] font-medium transition-all duration-300 ${selectedCategory === cat ? 'bg-[#f0e4e0] text-[#c9a8a8]' : 'bg-white text-[#b5a5a5] border border-[#f0ebe7] hover:bg-[#f0e4e0] hover:text-[#c9a8a8]'}`}
          >
            {cat}
          </a>
        ))}
      </div>
    )}

    {filteredShoes.length === 0 ? (
      <div class="text-center py-24">
        <p class="text-[#d4c5c5] text-sm font-light tracking-wide">No hay productos en esta categoría.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
        {filteredShoes.map((shoe) => (
          <article class="group cursor-pointer">
            <div class="relative aspect-[3/4] bg-[#f5f0ee] rounded-sm overflow-hidden mb-4">
              {shoe.image_url ? (
                <>
                  <img
                    src={shoe.image_url}
                    alt={shoe.name}
                    class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/15 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                </>
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-12 h-12 text-[#e0d5d0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              )}

              {shoe.quantity === 0 && (
                <div class="absolute top-3 left-3 bg-[#d4b5b5]/90 text-white text-[11px] tracking-[0.15em] uppercase px-3 py-1.5 font-medium rounded-sm">
                  Agotado
                </div>
              )}

              {shoe.quantity > 0 && shoe.quantity <= 3 && (
                <div class="absolute top-3 left-3 bg-[#e8c9a0]/90 text-white text-[11px] tracking-[0.15em] uppercase px-3 py-1.5 font-medium rounded-sm">
                  Últimas unidades
                </div>
              )}
            </div>

            <div class="px-1">
              <h3 class="font-['Playfair_Display'] text-base font-medium text-[#3d3d3d] leading-tight">{shoe.name}</h3>
              <div class="flex items-center justify-between mt-1.5">
                {shoe.category && (
                  <span class="text-[#c9a8a8]/70 text-[11px] tracking-[0.12em] uppercase font-light">{shoe.category}</span>
                )}
                <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full ${shoe.quantity > 0 ? 'bg-[#f0ebe7]' : 'bg-[#f5ecec]'}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${shoe.quantity > 0 ? 'bg-[#9cb4a8]' : 'bg-[#d4c5c5]'}`} />
                  <span class={`text-xs font-medium ${shoe.quantity > 0 ? 'text-[#7a6a6a]' : 'text-[#c9a8a8]'}`}>{shoe.quantity > 0 ? `${shoe.quantity} en stock` : 'Agotado'}</span>
                </span>
              </div>
              {shoe.description && (
                <p class="text-[#b5a5a5] text-xs font-light leading-relaxed mt-2 line-clamp-2">{shoe.description}</p>
              )}
            </div>
          </article>
        ))}
      </div>
    )}
  </main>

  <footer class="bg-white border-t border-[#f0ebe7]">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-12">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="flex items-baseline gap-2">
          <span class="font-['Playfair_Display'] text-lg font-semibold text-[#c9a8a8]">AD</span>
          <span class="text-[#c9a8a8]/30 text-[10px] tracking-[0.3em] uppercase">Web</span>
        </div>
        <p class="text-[#d4c5c5] text-xs font-light tracking-wider">
          &copy; {new Date().getFullYear()} AD Web — Diseños exclusivos
        </p>
      </div>
    </div>
  </footer>
</BaseLayout>
