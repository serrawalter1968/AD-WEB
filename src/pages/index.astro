---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getShoes } from '../lib/db';

const shoes = await getShoes();
const categories = [...new Set(shoes.map((s) => s.category).filter(Boolean))];
---

<BaseLayout>
  <header class="bg-white border-b border-stone-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-4xl font-['Playfair_Display'] font-semibold text-rose-400 tracking-tight">AD Web</h1>
          <p class="text-stone-400 mt-1 text-sm font-light italic">Diseños exclusivos en calzado femenino</p>
        </div>
        <a href="/admin/login" class="text-xs text-stone-400 hover:text-rose-400 transition-colors tracking-widest uppercase">Admin</a>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {categories.length > 0 && (
      <div class="flex gap-2 mb-10 flex-wrap justify-center">
        <a href="/" class="px-5 py-2 rounded-full bg-rose-50 text-rose-400 text-sm font-medium hover:bg-rose-100 transition-colors">
          Todas
        </a>
        {categories.map((cat) => (
          <a
            href={`/?categoria=${cat}`}
            class="px-5 py-2 rounded-full bg-stone-100 text-stone-500 text-sm font-medium hover:bg-stone-200 transition-colors"
          >
            {cat}
          </a>
        ))}
      </div>
    )}

    {shoes.length === 0 ? (
      <div class="text-center py-24">
        <p class="text-stone-300 text-lg font-light">No hay productos disponibles todavía.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
        {shoes.map((shoe) => (
          <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-500">
            <div class="aspect-square bg-stone-50 overflow-hidden relative">
              {shoe.image_url ? (
                <>
                  <img
                    src={shoe.image_url}
                    alt={shoe.name}
                    class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:brightness-110"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500">
                    <span class="bg-white/90 text-stone-700 px-6 py-2 rounded-full text-xs tracking-widest uppercase shadow-lg backdrop-blur-sm">
                      Ver más
                    </span>
                  </div>
                </>
              ) : (
                <div class="w-full h-full flex items-center justify-center text-stone-200">
                  <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              )}
            </div>
            <div class="p-5">
              <h3 class="font-['Playfair_Display'] font-semibold text-stone-800 text-lg leading-tight">{shoe.name}</h3>
              {shoe.category && (
                <span class="text-rose-300 text-xs tracking-widest uppercase mt-1.5 block">{shoe.category}</span>
              )}
              {shoe.description && (
                <p class="text-stone-400 text-sm mt-2 line-clamp-2 leading-relaxed font-light">{shoe.description}</p>
              )}
              <div class="mt-4 pt-3 border-t border-stone-100">
                <span class={`inline-flex items-center gap-1.5 text-xs font-medium ${shoe.quantity > 0 ? 'text-emerald-500' : 'text-stone-300'}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${shoe.quantity > 0 ? 'bg-emerald-500' : 'bg-stone-300'}`} />
                  {shoe.quantity > 0 ? `${shoe.quantity} en stock` : 'Agotado'}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </main>

  <footer class="border-t border-stone-100 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 text-center text-xs text-stone-300 font-light tracking-wider">
      &copy; {new Date().getFullYear()} AD Web — Diseños exclusivos en calzado femenino
    </div>
  </footer>
</BaseLayout>
