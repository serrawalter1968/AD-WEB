---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ShoeForm from '../../../components/react/ShoeForm';
import { getShoe } from '../../../lib/db';

const { id } = Astro.params;
const shoe = await getShoe(Number(id));
---
<AdminLayout>
  {shoe ? (
    <ShoeForm
      client:load
      initialData={{
        id: shoe.id,
        name: shoe.name,
        description: shoe.description,
        category: shoe.category,
        price: String(shoe.price),
        quantity: String(shoe.quantity),
        image_url: shoe.image_url,
      }}
    />
  ) : (
    <div class="text-center py-12 text-gray-500">Producto no encontrado</div>
  )}
</AdminLayout>
